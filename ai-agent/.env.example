# ===========================================
# ZKSplunk ai-agent (zkZap analyst) — config
# Copy to .env and fill in. .env is git-ignored.
# ===========================================

AI_AGENT_PORT=8787

# --- Local HTTPS for embedding inside Splunk dashboards ----------------------
# Generate with: npm run cert:localhost
# If both are set, the agent serves https://localhost:8787 instead of HTTP.
AI_AGENT_TLS_CERT=
AI_AGENT_TLS_KEY=

# --- Splunk evidence source ---
# Preferred: Splunk MCP Server (Splunkbase app 7931). Leave blank to use REST.
SPLUNK_MCP_ENDPOINT=
SPLUNK_MCP_TOKEN=
# Name of the MCP tool that runs SPL (defaults to run_splunk_search).
SPLUNK_MCP_SEARCH_TOOL=

# Fallback: Splunk REST API on :8089.
SPLUNK_REST_URL=https://localhost:8089
# Auth: either a REST token (Bearer) ...
SPLUNK_REST_TOKEN=
# ... or username + password (used to fetch a session key).
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
# Skip TLS verification (defaults true for localhost self-signed certs).
SPLUNK_INSECURE=true

# --- LLM assistant (evidence is always gathered from Splunk first) -----------
# Preferred for the hackathon: phrase answers through Splunk AI Toolkit's `| ai`
# command. Requires AI Toolkit installed/configured in Splunk and a user role
# with `apply_ai_commander_command`. Leave provider/model blank to use the
# default AI Toolkit connection/model.
SPLUNK_AI_TOOLKIT_ENABLED=false
SPLUNK_AI_TOOLKIT_PROVIDER=
SPLUNK_AI_TOOLKIT_MODEL=

# Fallback only: if Splunk AI Toolkit is disabled/unavailable, an external
# OpenAI-compatible model can phrase evidence-backed answers. If no key is set,
# the assistant returns deterministic, evidence-only answers.
# NVIDIA preferred when present; otherwise OpenAI-compatible.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=openai/gpt-oss-20b
# Optional second model, tried if the primary fails / times out / returns empty.
NVIDIA_FALLBACK_MODEL=
# Reasoning knob passed through to the model. Valid values are model-specific
# (deepseek accepts 'none'; gpt-oss accepts low|medium|high). If a model rejects
# the value the client transparently retries the call without it.
NVIDIA_REASONING_EFFORT=
# Per-request abort timeout (ms) and extra retries per model on transient errors.
NVIDIA_REQUEST_TIMEOUT_MS=30000
NVIDIA_RETRY_COUNT=1
# Generic OpenAI-compatible overrides (used when NVIDIA_* is unset).
OPENAI_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
