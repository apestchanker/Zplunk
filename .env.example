# ===========================================
# ZKSplunk Environment Configuration
# ===========================================

# Splunk HTTP Event Collector (HEC) — Splunk Cloud or self-hosted, port :8088.
SPLUNK_HEC_URL=https://your-instance.splunkcloud.com:8088
SPLUNK_HEC_TOKEN=your-hec-token-here
SPLUNK_INDEX=zksplunk
SPLUNK_SOURCETYPE=midnight:vitals

# Midnight Proof Server
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300
PROOF_SERVER_HEALTH_PATH=/health
PROOF_SERVER_VERSION_PATH=/version

# Midnight Network Indexer + Node.
# Live default: Midnight's hosted PREVIEW network (Indexer API v4). Only the
# proof server (above) runs locally.
MIDNIGHT_INDEXER_URL=https://indexer.preview.midnight.network/api/v4/graphql
MIDNIGHT_NODE_URL=https://rpc.preview.midnight.network
MIDNIGHT_NETWORK_ID=preview

# Polling Intervals (milliseconds)
POLL_INTERVAL_PROOF_SERVER_MS=15000
POLL_INTERVAL_INDEXER_MS=20000
POLL_INTERVAL_NODE_MS=30000
POLL_INTERVAL_CHAIN_MS=30000
POLL_INTERVAL_CONTRACTS_MS=60000
POLL_INTERVAL_VERSION_MS=300000
POLL_INTERVAL_WALLET_MS=300000
CONNECTOR_HEARTBEAT_INTERVAL_MS=60000

# Local JSONL sink (development; mirror events + capture failed HEC deliveries)
ENABLE_LOCAL_JSONL_SINK=false
LOCAL_JSONL_PATH=./out/zksplunk-events.jsonl

# Splunk MCP Server (for AI agent bridge)
SPLUNK_MCP_ENDPOINT=https://your-instance.splunkcloud.com/mcp

# Wallet reward address for DUST generation checks (optional)
# WALLET_CARDANO_REWARD_ADDRESS=stake1...

# ============================================
# On-chain attestation contract (optional)
# ============================================
# Deployed ZKSplunk contract address on the target network
ZKSPLUNK_CONTRACT_ADDRESS=
# Target Midnight network for attestation (preview | preprod | mainnet)
ZKSPLUNK_ATTEST_NETWORK=preview
# Set to 'true' to enable on-chain attestation (connector / demoLand path)
ZKSPLUNK_ATTEST_ENABLED=false
# NOTE: the live zkMonitor runner uses ENABLE_ATTESTATION instead.
# See zkMonitor/.env.zkmonitor and docs/BLOCKCHAIN_PIPELINE_SETUP.md.
# ENABLE_ATTESTATION=true
