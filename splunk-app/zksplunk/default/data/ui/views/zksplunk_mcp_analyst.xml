<dashboard version="1.1" theme="dark">
  <label>ZKSplunk MCP Analyst</label>
  <description>Open the local ZKSplunk AI analyst chat.</description>

  <row>
    <panel>
      <html>
        <style>
          .zk-chat-fallback {
            min-height: 420px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #071018;
            border: 1px solid #263241;
            color: #e6edf3;
            font-family: "Avenir Next", "Helvetica Neue", Helvetica, Arial, sans-serif;
          }
          .zk-chat-card {
            max-width: 520px;
            text-align: center;
            padding: 34px;
            border: 1px solid rgba(151, 178, 205, .2);
            background: rgba(11, 20, 30, .86);
          }
          .zk-chat-card h2 {
            margin: 0 0 10px;
            font-size: 28px;
          }
          .zk-chat-card p {
            margin: 0 0 22px;
            color: #9aa6b2;
            line-height: 1.45;
          }
          .zk-chat-card a {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 44px;
            padding: 0 18px;
            border-radius: 6px;
            background: #7dbb55;
            color: #07120a;
            text-decoration: none;
            font-weight: 900;
          }
        </style>
        <div class="zk-chat-fallback">
          <div class="zk-chat-card">
            <h2>ZKSplunk MCP Analyst</h2>
            <p>Splunk's iframe restrictions are not reliably rendering the local chat. Open the analyst in a separate local window.</p>
            <a href="http://localhost:8787" target="_blank">Open MCP Analyst</a>
          </div>
        </div>
      </html>
    </panel>
  </row>
</dashboard>
