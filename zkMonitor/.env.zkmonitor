# ===========================================
# ZKSplunk zkMonitor Environment (TEMPLATE — copy to .env and fill in secrets)
# ===========================================
# NOTE: .env is git-ignored. Never commit real HEC tokens. This template holds
# placeholders only.

ZKSPLUNK_MODE=zkmonitor
ZKSPLUNK_DAPP_NAME=BlindOracle
ZKSPLUNK_ENVIRONMENT=zkmonitor

# --- Splunk HTTP Event Collector (REQUIRED) ---
# Cloud uses :8088. For a LOCAL Splunk next to midnight-local-dev, use :8090
# (the Midnight indexer binds :8088). See docs/SPLUNK_API_INTEGRATION.md.
SPLUNK_HEC_URL=https://your-instance.splunkcloud.com:8088
SPLUNK_HEC_TOKEN=replace-with-your-hec-token
SPLUNK_INDEX=zksplunk
SPLUNK_SOURCETYPE=midnight:vitals
SPLUNK_SOURCE=zksplunk-zkmonitor

# --- Live Midnight infrastructure (REQUIRED for real vitals) ---
# All three endpoints below use the PUBLIC Midnight preview network.
# No local node or indexer needed. Only the proof server runs locally
# (it generates ZK proofs — CPU intensive, but runs on any machine).
#
# Public preview endpoints:
MIDNIGHT_INDEXER_URL=https://indexer.preview.midnight.network/api/v4/graphql
# Indexer WebSocket is derived automatically: https->wss, append /ws
# MIDNIGHT_INDEXER_WS_URL=wss://indexer.preview.midnight.network/api/v4/graphql/ws
MIDNIGHT_NODE_URL=https://rpc.preview.midnight.network
# Network id: 'preview' for the preview network, 'undeployed' for local dev.
MIDNIGHT_NETWORK_ID=preview
#
# Proof server: runs locally (no public endpoint available).
# Install via midnight-local-dev or run the standalone proof-server Docker image.
# See docs/BLOCKCHAIN_PIPELINE_SETUP.md for setup instructions.
# Default port is 6300.
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300
# Wallet address to observe PUBLIC unshielded activity (no private key needed).
MIDNIGHT_WALLET_ADDRESS=

# Proof server probe paths (try /health, fall back to /version on 404).
PROOF_SERVER_HEALTH_PATH=/health
PROOF_SERVER_VERSION_PATH=/version

# --- Polling intervals (ms) — all overridable ---
POLL_INTERVAL_PROOF_SERVER_MS=15000
POLL_INTERVAL_INDEXER_MS=20000
POLL_INTERVAL_NODE_MS=30000
POLL_INTERVAL_CHAIN_MS=30000
POLL_INTERVAL_CONTRACTS_MS=60000
POLL_INTERVAL_VERSION_MS=300000
POLL_INTERVAL_WALLET_MS=300000
CONNECTOR_HEARTBEAT_INTERVAL_MS=60000
# On-chain status reader poll interval (npm run onchain-status).
# READ-ONLY: no wallet/seed needed. Set ZKSPLUNK_CONTRACT_ADDRESS to enable.
ONCHAIN_POLL_INTERVAL_MS=60000

# --- Local JSONL sink (development; capture events without a running Splunk) ---
ENABLE_LOCAL_JSONL_SINK=false
LOCAL_JSONL_PATH=./out/zksplunk-events.jsonl

# --- On-chain attestation — RELAYER MODEL (optional) ---
# Leave ENABLE_ATTESTATION=false until everything below is configured.
# With attestation disabled, zkMonitor uses MockAttestationClient so the
# Splunk event path still runs end-to-end.
#
# PRIVACY MODEL:
#   - The OPERATOR (this collector) holds only an UNFUNDED Zswap keypair
#     (OPERATOR_ZSWAP_SEED). It proves the ZK circuit locally via the proof
#     server and POSTs the proven-but-unbalanced tx to the RELAYER.
#   - The RELAYER holds the funded SYSTEM wallet (RELAYER_WALLET_SEED) and
#     pays all DUST fees. On-chain: public sees only the SYSTEM wallet paid;
#     the operator is cryptographically unlinkable from the attestation.
#   - The relayer HTTP endpoint is the off-chain de-anonymization risk.
#     Use mTLS / VPN between collectors and the relayer in production.
#
# OPERATOR SETUP (run once per collector host):
#   1. Generate an unfunded Zswap seed (operator keypair, no NIGHT/DUST):
#        node -e "process.stdout.write(require('node:crypto').randomBytes(32).toString('hex'))"
#   2. Set OPERATOR_ZSWAP_SEED below (NEVER commit with a real seed).
#      This wallet needs NO funding — it holds only ZK keys.
#   3. Ensure a relayer is running (see RELAYER SETUP below) and set
#      ATTESTATION_RELAYER_URL to its base URL.
#   4. Set ZKSPLUNK_CONTRACT_ADDRESS (output of `npm run deploy`).
#   5. Set ENABLE_ATTESTATION=true and restart.
#
# RELAYER SETUP (run once, on a trusted host with funded SYSTEM wallet):
#   1. Generate a funded relayer seed (this wallet holds NIGHT → DUST):
#        node -e "process.stdout.write(require('node:crypto').randomBytes(32).toString('hex'))"
#   2. Set RELAYER_WALLET_SEED in the relayer's env (NOT here).
#   3. Fund the relayer wallet with NIGHT, register for DUST generation.
#   4. Run: npm run relayer   — starts the HTTP relay service on RELAYER_PORT.
#   5. (Optional) add mTLS / API key / rate-limit config in attestation-relayer.ts.
#
# Critical-only: attestations are submitted ONLY when a vital's status is
# 'critical'. Healthy/warning/degraded vitals are never sent on-chain.
ENABLE_ATTESTATION=false
ZKSPLUNK_CONTRACT_ADDRESS=
#--- THESE SEEDS are for Preview network only. You will never store SEEDS in a real deployment. They are used here for testing and demonstration purposes only. ---
# Admin funded SYSTEM wallet seed (64-char hex). This wallet holds NIGHT → DUST for tx fees.
MIDNIGHT_WALLET_SEED=
# Operator unfunded Zswap keypair seed (64-char hex).
# This wallet holds NO NIGHT/DUST. It is used only for ZK proof generation.
# WARNING: Keep this secret. Never commit to version control.
OPERATOR_ZSWAP_SEED=
# Relayer funded wallet seed (64-char hex). This wallet receives the proven-but-unbalanced tx from the operator, pays fees, and submits on-chain.
RELAYER_WALLET_SEED=
# -- BE SURE THE .ENV is GIT-IGNORED! These seeds are for testing only. Do NOT use them in production or share them publicly. ---

# URL of the attestation-relayer service (holds the funded SYSTEM wallet).
ATTESTATION_RELAYER_URL=http://localhost:7300

